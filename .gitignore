# 依赖
node_modules/

# CodeGraph 本地索引
.codegraph/

# 敏感配置（含 SMTP 密码、API 密钥）
send/config.json
send/config.example.json

# 进程日志（运行时诊断）
logs/

# 发送日志与队列（运行时数据，含收件人邮箱）
send/send-log.json
send/send-log-test.json
send/session-log.json
send/send-batch.json
# 用户运行时数据（数据库、缓存、收件箱、发送状态等，全部不进版本控制）
data/*
!data/.gitkeep

# 背调报告（含邮箱、地址）
reports/

# 用户数据文件
*.csv
*.xlsx
*.xls

# Electron 构建产物
dist/
out/

# 打包产物（输出到外部目录）
product/

# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# 外部工具缓存
.serena/
.understand-anything/
electron/renderer/node_modules/

# 运行时生成的数据
data/send-bodies.json
send/send-log.json.tmp

# IDE
.vscode/
.idea/
