{
  "name": "prospecting-email-send",
  "version": "1.0.0",
  "description": "拉美开发信桌面工具 — 背调 + 模板 + 自动发送",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.milogin.prospecting-email",
    "productName": "Prospecting Email",
    "directories": {
      "output": "../product"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "files": [
      "electron/**",
      "templates/**",
      "send/config.json",
      "send/signature.html",
      "assets/**",
      "package.json",
      "node_modules/**",
      "!node_modules/puppeteer/**",
      "!node_modules/puppeteer-extra/**",
      "!node_modules/puppeteer-extra-plugin-stealth/**"
    ],
    "extraResources": []
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "imap": "^0.8.19",
    "nodemailer": "^6.9.0",
    "puppeteer": "^25.1.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  }
}
