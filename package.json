{
  "name": "prospecting-email-send",
  "version": "1.1.0",
  "description": "拉美开发信桌面工具 — 背调 + 模板 + 自动发送",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron-vite dev",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "pack": "electron-vite build && electron-builder --win"
  },
  "build": {
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "appId": "com.milogin.prospecting-email",
    "productName": "Milogin's Prospector.",
    "directories": {
      "output": "../product-v6"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "files": [
      "dist/**",
      "electron/**",
      "templates/**",
      "send/config.example.json",
      "send/signature.html",
      "assets/**",
      "package.json",
      "node_modules/**"
    ],
    "asar": true,
    "extraResources": [{ "from": "assets", "to": "assets" }]
  },
  "dependencies": {
    "imap": "^0.8.19",
    "nodemailer": "^6.9.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-reloader": "^1.2.3",
    "electron-vite": "^5.0.0",
    "vite": "^7.3.6"
  }
}
