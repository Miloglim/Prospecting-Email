{
  "name": "prospecting-email-send",
  "version": "2.8.1",
  "description": "拉美开发信桌面工具 — 背调 + 模板 + 自动发送",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron-vite dev",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "pack": "electron-vite build && electron-builder --win",
    "build-only": "electron-vite build && electron-builder --win --publish never",
    "ship": "electron-vite build && electron-builder --win --publish never",
    "sync-oss": "node scripts/sync-oss.js"
  },
  "build": {
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "appId": "com.miloglim.prospecting-email",
    "productName": "Milogin's Prospector.",
    "directories": {
      "output": "../dist-release"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "Miloglim",
      "repo": "Prospecting-Email"
    },
    "files": [
      "dist/**",
      "electron/**",
      "templates/**",
      "send/config.example.json",
      "send/signature.html",
      "assets/**",
      "package.json",
      "node_modules/**"
    ],
    "asar": true,
    "afterPack": "./scripts/embed-icon.js",
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.6.2",
    "imap": "^0.8.19",
    "mailparser": "^3.9.12",
    "nodemailer": "^6.9.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-reloader": "^1.2.3",
    "electron-vite": "^5.0.0",
    "rcedit": "^5.0.2",
    "vite": "^7.3.6"
  }
}
